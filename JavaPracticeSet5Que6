import java.util.Scanner;
public class JavaPracticeSet5Que6 {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter the no. to find the factorial of:");
        int n=sc.nextInt();
        long factorial=1;
        int temp=n;
        if(n==0){
            System.out.println("Factorial=1");
        }
        else if(n<0){
            System.out.println("Factorial not defined for this no.");
        }
        else{
        while(temp>0){
           factorial*=temp;
           temp-=1;
        }
         System.out.println(factorial);
    }
       
    }
}
