import java.util.Scanner;
public class JavaPracticeSet5Que5 {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.println("Enter the no. to find the factorial of:");
        int n=sc.nextInt();
        int factorial=1;
        if(n==0){
            System.out.println("Factorial=1");
        }
        else if(n<0){
            System.out.println("Factorial not defined for this no.");
        }
        else{
        for(int i=n;i>0;i--){
            factorial=factorial*i;
            
        }
         System.out.println(factorial);
    }
       
    }
}
