import java.util.Scanner;
public class JavaPracticeSet5Que3 {
    public static void main(String[] args) {
        Scanner sc= new Scanner(System.in);
        System.out.println("Get the multiplication table of any number:-");
        System.out.println("Enter the no.:");
        int n=sc.nextInt();
        System.out.println("Enter the place till which you want the multiplication table:");
        int a=sc.nextInt();
        System.out.println("Multiplication table:-");
        for(int i=1;i<=a;i++){
            System.out.println(n*i);
        }
        
    }
}
