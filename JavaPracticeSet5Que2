import java.util.Scanner;
public class JavaPracticeSet5Que2 {
    public static void main(String[] args) {
        Scanner sc= new Scanner(System.in);
        System.out.println("The no. of first even numbers whose sum you want:");
        int n=sc.nextInt();
        int i=0;
        int sum=0;
        while(i<n){
            int even=2*i;
            sum=sum+even;
            i=i+1;
            
        }
        System.out.println(sum);
    }
    
}
